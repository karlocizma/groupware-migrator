# Groupware Migrator — environment configuration
# Copy this file to .env and fill in the values.
# start.sh will generate .env automatically on first run.

# ── Required ──────────────────────────────────────────────────────────────────

# First admin account (created on first startup when no users exist)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# JWT signing secret — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_me_with_a_random_64_char_hex_string

# ── Optional ──────────────────────────────────────────────────────────────────

# Set to true when running behind HTTPS (prevents cookie being sent over HTTP)
# COOKIE_SECURE=true

# Public-facing URL used in email notification "View job" links
# SITE_URL=https://migrate.example.com

# Session token lifetime in hours (default: 8)
# JWT_TTL_HOURS=8

# Bind address and port (venv / uvicorn mode only; Docker uses docker-compose.yml)
# HOST=127.0.0.1
# PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string — SQLite (data/state.db) is used when absent
# DATABASE_URL=postgresql://user:password@localhost:5432/groupware

# ── Distributed job queue ─────────────────────────────────────────────────────

# Redis URL for the groupware-migrator-worker process (horizontal scaling)
# REDIS_URL=redis://localhost:6379

# ── Credential vault ──────────────────────────────────────────────────────────

# Fernet key for encrypting scheduled job credentials at rest
# Generate: python3 -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).rstrip(b'=').decode())"
# VAULT_KEY=

# ── Email notifications ───────────────────────────────────────────────────────

# SMTP server for job completion/failure/cancellation emails
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# SMTP_TLS=starttls   # starttls | ssl | none
# SMTP_TIMEOUT=10

# ── LDAP / Active Directory ───────────────────────────────────────────────────

# Coexists with local password auth; auto-provisions accounts on first login
# LDAP_HOST=dc.corp.example.com
# LDAP_PORT=389
# LDAP_USE_SSL=false
# LDAP_USE_STARTTLS=false
# LDAP_BASE_DN=OU=Users,DC=corp,DC=example
# LDAP_BIND_DN=CN=svc-migrator,OU=SvcAccts,DC=corp,DC=example
# LDAP_BIND_PASSWORD=
# LDAP_USER_FILTER=(userPrincipalName={email})
# LDAP_EMAIL_ATTR=mail
# LDAP_DEFAULT_ROLE=operator
